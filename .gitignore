# ======================================================================
# HOSPITAL MANAGEMENT SYSTEM - .gitignore
# ======================================================================
# Team: OctNov
# Lead: Koushal Jha
# Version: 2.1.0
# Date: 2026-03-16
# ======================================================================

# ======================================================================
# BACKEND - DO NOT COMMIT
# ======================================================================
backend/node_modules/
backend/build/
backend/temp/
backend/coverage/
backend/.env
backend/.env.local
backend/.env.*.local
backend/logs/
backend/*.log
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/package-lock.json
backend/yarn.lock

# Keep backend source (these SHOULD be committed)
!backend/src/
!backend/server.js
!backend/package.json
!backend/nodemon.json

# Tests - Will be added later in testing phase
backend/tests/

# ======================================================================
# DATABASE - DO NOT COMMIT
# ======================================================================
database/*.sql
database/development/*.sql
database/migrations/development/*.sql
database/seeds/development/*.sql
database/logs/
database/*.log

