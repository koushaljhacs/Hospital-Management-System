!database/migrations/development/007_create_inventory.sql
!database/migrations/development/008_create_suppliers.sql
!database/migrations/development/009_create_purchase_orders.sql
!database/migrations/development/010_create_beds.sql
!database/migrations/development/011_create_invoices.sql
!database/migrations/development/012_create_insurance_providers.sql
!database/migrations/development/013_create_lab_tests.sql
!database/migrations/development/014_create_equipment.sql
!database/migrations/development/015_create_test_results.sql
!database/migrations/development/016_create_test_orders.sql
!database/migrations/development/017_create_labs.sql
!database/migrations/development/018_create_specimens.sql
!database/migrations/development/019_create_tasks.sql
!database/migrations/development/020_create_shifts.sql
!database/migrations/development/021_create_break_glass_access.sql
!database/migrations/development/022_create_audit_logs.sql
!database/migrations/development/023_create_radiology_images.sql
!database/migrations/development/024_integration_tables.sql
!database/migrations/development/025_security_tables.sql
!database/migrations/development/026_performance_tables.sql
!database/triggers/business_rules.sql
!database/schema.sql

# ======================================================================
# FRONTEND - DO NOT COMMIT
# ======================================================================
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/temp/
frontend/.env
frontend/.env.local

# ======================================================================
# INFRASTRUCTURE - DO NOT COMMIT
# ======================================================================
infrastructure/ssl/development/
infrastructure/ssl/staging/
infrastructure/ssl/production/fullchain.pem
infrastructure/ssl/production/privkey.pem
infrastructure/ssl/production/dhparam.pem
infrastructure/logs/
infrastructure/*.log

# Keep infrastructure configs (these SHOULD be committed)
!infrastructure/nginx/development/
!infrastructure/nginx/staging/
!infrastructure/nginx/production/default.conf
!infrastructure/nginx/snippets/
!infrastructure/pm2/development/
!infrastructure/pm2/staging/
!infrastructure/pm2/production/ecosystem.config.js
!infrastructure/cloudflare/production/
!infrastructure/scripts/deploy/
!infrastructure/scripts/backup/
!infrastructure/scripts/verify/
!infrastructure/monitoring/

# ======================================================================
# DOCKER - DO NOT COMMIT
# ======================================================================
docker/development/.env
docker/staging/.env
docker/production/.env
docker/development/*.log
docker/staging/*.log
docker/production/*.log

# Keep Docker configs (these SHOULD be committed)
!docker/development/docker-compose.yml
!docker/development/Dockerfile.dev
!docker/staging/docker-compose.yml
!docker/staging/Dockerfile.staging
!docker/production/docker-compose.yml
!docker/production/Dockerfile.prod

# ======================================================================
# DOCUMENTATION - KEEP ALL (COMMIT)
# ======================================================================
docs/
!docs/api/
!docs/database/
!docs/guides/

# ======================================================================
# PLANNING FOLDER - SOURCE FILES IGNORE, DIST KEEP
# ======================================================================
# Ignore source files in planning
planning/index.html
planning/architecture.html
planning/architecture/architecture.html
planning/style.css
planning/animations.css
planning/script.js
planning/architecture/css/architecture.css
planning/architecture/js/architecture.js

# Keep production dist folder
!planning/dist/
!planning/dist/index.html
!planning/dist/css/style.min.css
!planning/dist/css/animations.min.css
!planning/dist/js/script.min.js
!planning/dist/architecture/architecture.html
!planning/dist/architecture/css/architecture.min.css
!planning/dist/architecture/js/architecture.min.js
!planning/dist/assets/

# Keep build scripts and documentation
!planning/build-minify.ps1
!planning/README.md
!planning/LICENSE.md
!planning/plan.txt
!planning/todo.md
!planning/database-requirement.txt
!planning/tech-stack.md
!planning/api-requirement.txt

# Keep necessary assets
!planning/assets/
!planning/assets/background.png
!planning/assets/health monitor.png
!planning/assets/monitoring.png
!planning/assets/reception.png

# ======================================================================
# DEVELOPMENT FOLDER - IGNORE (Only for local dev)
# ======================================================================
development/
development/**/*

# ======================================================================
# PHASE 2 FOLDER - IGNORE (Planning documents)
# ======================================================================
phase 2/
phase 2/**/*

# ======================================================================
# IDE AND EDITOR FILES
# ======================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ======================================================================
# OS FILES
# ======================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ======================================================================
# TEST COVERAGE
# ======================================================================
coverage/
.nyc_output/
*.lcov

# ======================================================================
# TEMPORARY FILES
# ======================================================================
*.tmp
*.temp
*.bak
*.backup
*.log.*
*-backup/


# ======================================================================
# DEVELOPMENT & PHASE 2 FOLDERS - DO NOT COMMIT
# ======================================================================
development/
phase 2/
phase 2/*
!/phase 2/README.md
!/phase 2/requirements.md

# ======================================================================
# END OF .gitignore
# ======================================================================